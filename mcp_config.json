{
  "mcpServers": {
    "cloudera-raz-storage": {
      "command": "uv",
      "args": [
        "run",
        "--quiet",
        "--with",
        "git+https://github.com/jvprosser/hdfs-mcp-server.git",
        "hdfs-mcp-server"
      ],
      "env": {
        "HADOOP_CONF_DIR": "/etc/hadoop/conf",
        "JAVA_HOME": "/usr/lib/jvm/java-8-openjdk-amd64",
        "ARROW_LIBHDFS_DIR": "/runtime-addons/hadoop-cli-7.3.1.101-c2jhs/usr/lib",
        "LD_LIBRARY_PATH": "/usr/lib/jvm/java-8-openjdk-amd64/jre/lib/amd64/server:/usr/lib/jvm/java-8-openjdk-amd64/jre/lib/amd64:/runtime-addons/hadoop-cli-7.3.1.101-c2jhs/usr/lib:/runtime-addons/hadoop-cli-7.3.1.101-c2jhs/usr/lib/native",
        "CLASSPATH": "/etc/hadoop/conf:/runtime-addons/hadoop-cli-7.3.1.101-c2jhs/usr/lib/*:/runtime-addons/hadoop-cli-7.3.1.101-c2jhs/usr/lib/hadoop/*:/runtime-addons/hadoop-cli-7.3.1.101-c2jhs/usr/lib/hadoop/lib/*:/runtime-addons/hadoop-cli-7.3.1.101-c2jhs/usr/lib/hadoop-hdfs/*:/runtime-addons/hadoop-cli-7.3.1.101-c2jhs/usr/lib/hadoop-hdfs/lib/*:/usr/lib/hadoop/*:/usr/lib/hadoop/lib/*",
        "CDP_WORKLOAD_USER": "$CML_USER"
      }
    }
  }
}
